## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build folders
**/bin/
**/obj/

# Rider
.idea/

# Visual Studio Code workspace settings
.vscode/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
**/packages/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Certificates
*.pfx

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Backup files
*~

# Test results
TestResults/
**/TestResults/

# JetBrains Rider
.idea/

# Visual Studio Temporary Files
*.cache
*.log

# Local publish
**/publish/

# EF local DB
*.mdf
*.ldf

# VS Code extensions
.vscode/*
!.vscode/launch.json

# Avoid committing binaries and packages
*.dll
*.exe
*.pdb
*.vsix

# Sonar artifacts
.sonarqube/

# Others
*.vspscc
*.vssscc

# Keep this file tracked
!.gitignore
